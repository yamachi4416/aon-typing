{
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.2",
  "browserslist": [
    "since 2023-03-01 and not Firefox < 121"
  ],
  "scripts": {
    "postinstall": "nuxt prepare",
    "build": "nuxt generate",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "lint": "pnpm run '/lint:.*/'",
    "lint:knip": "knip",
    "lint:typecheck": "nuxt typecheck",
    "lint:scripts": "eslint .",
    "lint:styles": "stylelint app/**/*.{scss,vue}",
    "test": "vitest",
    "test:unit": "vitest --project libs --project app",
    "test:e2e": "vitest --project e2e",
    "script:preview:dist": "jiti ./scripts/preview-server -d ./dist",
    "script:problem": "jiti ./scripts/problem",
    "script:problem:generate": "jiti ./scripts/problem generate -i ./data -o ./app/assets/api"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/seo": "^5.1.3",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "citty": "^0.2.2",
    "defu": "^6.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "google-fonts-helper": "^3.7.4",
    "happy-dom": "^20.9.0",
    "jiti": "^2.7.0",
    "knip": "^6.12.1",
    "nuxt": "^4.4.4",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.11.0",
    "stylelint-browser-compat": "1.0.0-beta.180",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "terser": "^5.47.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.34",
    "vue-component-type-helpers": "^3.2.8",
    "vue-gtag-next": "^1.14.0",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.8"
  }
}
